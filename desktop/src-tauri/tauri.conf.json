{
    "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
    "productName": "VibeDrop",
    "version": "0.1.4",
    "identifier": "com.vibedrop.desktop",
    "build": {
        "frontendDist": "../src",
        "beforeDevCommand": "",
        "beforeBuildCommand": ""
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "label": "main",
                "create": false,
                "title": "VibeDrop",
                "width": 420,
                "height": 560,
                "resizable": true,
                "center": true,
                "decorations": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "macOS": {
            "minimumSystemVersion": "10.15"
        },
        "resources": [
            "../static/**/*"
        ]
    }
}
